generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Multi-Tenancy ---

model Tenant {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String    @unique
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  staff                  Staff[]
  patients               Patient[]
  appointments           Appointment[]
  services               Service[]
  invoices               Invoice[]
  expenses               Expense[]
  inventory              Inventory[]
  labOrders              LabOrder[]
  treatmentPlans         TreatmentPlan[]
  treatmentPlanItems     TreatmentPlanItem[]
  prescriptions          Prescription[]
  prescriptionItems      PrescriptionItem[]
  patientAllergies       PatientAllergy[]
  medicalConditions      MedicalCondition[]
  patientMedications     PatientMedication[]
  visitRecords           VisitRecord[]
  toothConditions        ToothCondition[]
  oralConditions         OralCondition[]
  oralTissueFindings     OralTissueFinding[]
  periodontalMeasurements PeriodontalMeasurement[]
  patientDocuments       PatientDocument[]
  patientSurgeries       PatientSurgery[]
  patientFamilyHistory   PatientFamilyHistory[]

  @@index([createdAt])
  @@map("tenants")
}

// --- Enums ---

enum StaffRole {
  ADMIN
  DOCTOR
  ASSISTANT
  RECEPTIONIST

  @@map("staff_role")
}

enum AppointmentStatus {
  SCHEDULED
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("appointment_status")
}

enum InvoiceStatus {
  PAID
  PENDING
  OVERDUE

  @@map("invoice_status")
}

enum ExpenseStatus {
  PAID
  PENDING

  @@map("expense_status")
}

enum LabOrderStatus {
  SENT
  IN_PROGRESS
  RECEIVED
  DELIVERED

  @@map("lab_order_status")
}

// --- Models ---

model Staff {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  displayId   String?   @unique @map("display_id")
  name        String
  role        StaffRole
  title       String?
  email       String    @unique
  phone       String?
  status      String?   @default("Online")
  avatarUrl   String?   @map("avatar_url")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  appointments Appointment[]
  prescriptions Prescription[]

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("staff")
}

model Patient {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  displayId      String?   @unique @map("display_id")
  name           String
  email          String?
  phone          String?
  phone2         String?
  dob            DateTime? @db.Date
  gender         String?
  bloodGroup     String?   @map("blood_group")
  avatarInitials String?   @map("avatar_initials")
  colorGradient  String?   @map("color_gradient")
  address        String?
  postCode       String?   @map("post_code")
  city           String?
  maritalStatus  String?   @map("marital_status")
  occupation     String?
  insurance      String?
  ssn            String?
  idNumber       String?   @map("id_number")
  medicalAlert   String?   @map("medical_alert")
  referredBy     String?   @map("referred_by")
  notes          String?
  medicalNotes   String?   @map("medical_notes")
  isDeceased     Boolean?  @default(false) @map("is_deceased")
  isSigned       Boolean?  @default(false) @map("is_signed")
  status         String?   @default("Active")
  smokingStatus  String?   @default("Never") @map("smoking_status")
  alcoholUse     String?   @default("None") @map("alcohol_use")
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  appointments      Appointment[]
  invoices          Invoice[]
  treatmentPlans    TreatmentPlan[]
  prescriptions     Prescription[]
  labOrders         LabOrder[]
  patientDocuments  PatientDocument[]
  patientAllergies  PatientAllergy[]
  medicalConditions MedicalCondition[]
  patientMedications PatientMedication[]
  patientSurgeries  PatientSurgery[]
  patientFamilyHistory PatientFamilyHistory[]
  visitRecords      VisitRecord[]
  toothConditions   ToothCondition[]
  oralConditions    OralCondition[]
  oralTissueFindings OralTissueFinding[]
  periodontalMeasurements PeriodontalMeasurement[]

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("patients")
}

model Appointment {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String            @map("tenant_id") @db.Uuid
  displayId String?           @unique @map("display_id")
  patientId String            @map("patient_id") @db.Uuid
  doctorId  String            @map("doctor_id") @db.Uuid
  serviceId String?           @map("service_id") @db.Uuid
  date      DateTime          @db.Date
  time      DateTime          @db.Time(6)
  duration  Int
  status    AppointmentStatus? @default(SCHEDULED)
  treatment String?
  color     String?
  notes     String?
  createdAt DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?         @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  doctor  Staff   @relation(fields: [doctorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("appointments")
}

model Service {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String
  category        String
  price           Decimal   @db.Decimal
  durationMinutes Int?      @map("duration_minutes")
  duration        Int?
  description     String?
  popular         Boolean?  @default(false)
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  appointments        Appointment[]
  treatmentPlanItems  TreatmentPlanItem[]

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("services")
}

model Invoice {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String         @map("tenant_id") @db.Uuid
  displayId String?        @unique @map("display_id")
  patientId String         @map("patient_id") @db.Uuid
  amount    Decimal        @db.Decimal
  date      DateTime?      @db.Date
  status    InvoiceStatus? @default(PENDING)
  method    String?
  treatment String?
  dueDate   DateTime?      @db.Date @map("due_date")
  createdAt DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?      @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("invoices")
}

model Expense {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  displayId   String?        @unique @map("display_id")
  category    String
  description String
  amount      Decimal        @db.Decimal
  date        DateTime       @db.Date
  status      ExpenseStatus? @default(PENDING)
  method      String?
  createdAt   DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime?      @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("expenses")
}

model Inventory {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  displayId String?   @unique @map("display_id")
  name      String
  category  String
  quantity  Int       @default(0)
  minLevel  Int       @default(10) @map("min_level")
  minStock  Int?      @default(0) @map("min_stock")
  unit      String?
  location  String?
  supplier  String?
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("inventory")
}

model LabOrder {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  displayId       String?         @unique @map("display_id")
  patientId       String          @map("patient_id") @db.Uuid
  labName         String          @map("lab_name")
  itemDescription String          @map("item_description")
  sendDate        DateTime        @map("send_date") @db.Date
  returnDate      DateTime?       @map("return_date") @db.Date
  cost            Decimal?        @db.Decimal
  status          LabOrderStatus? @default(SENT)
  createdAt       DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?       @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("lab_orders")
}

model TreatmentPlan {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  patientId String    @map("patient_id") @db.Uuid
  title     String
  status    String?   @default("Active")
  notes     String?
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient             @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items   TreatmentPlanItem[]

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("treatment_plans")
}

model TreatmentPlanItem {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  planId        String    @map("plan_id") @db.Uuid
  serviceId     String?   @map("service_id") @db.Uuid
  serviceName   String    @map("service_name")
  toothList     String?   @map("tooth_list")
  price         Decimal   @db.Decimal
  status        String?   @default("Planned")
  step          Int?
  scheduledDate DateTime? @map("scheduled_date") @db.Date
  notes         String?
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  plan    TreatmentPlan @relation(fields: [planId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  service Service?      @relation(fields: [serviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("treatment_plan_items")
}

model Prescription {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  patientId  String    @map("patient_id") @db.Uuid
  doctorId   String?   @map("doctor_id") @db.Uuid
  doctorName String?   @map("doctor_name")
  date       DateTime? @default(now()) @map("date") @db.Timestamptz(6)
  notes      String?
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient            @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  doctor  Staff?             @relation(fields: [doctorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items   PrescriptionItem[]

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  prescriptionId String    @map("prescription_id") @db.Uuid
  medicationName String    @map("medication_name")
  dosage         String?
  frequency      String?
  duration       String?
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("prescription_items")
}

model PatientAllergy {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  patientId String    @map("patient_id") @db.Uuid
  allergen  String?
  severity  String?   @default("outline")
  reaction  String?
  notes     String?
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("patient_allergies")
}

model MedicalCondition {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  patientId     String    @map("patient_id") @db.Uuid
  conditionName String?    @map("condition_name")
  diagnosedDate DateTime? @map("diagnosed_date") @db.Date
  status        String?
  notes         String?
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("medical_conditions")
}

model PatientMedication {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  patientId      String    @map("patient_id") @db.Uuid
  medicationName String?    @map("medication_name")
  dosage         String?
  frequency      String?
  notes          String?
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("patient_medications")
}

model VisitRecord {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  patientId String    @map("patient_id") @db.Uuid
  date      DateTime  @db.Date
  treatment String
  doctor    String
  notes     String?
  tooth     String?
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("visit_records")
}

model ToothCondition {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  patientId   String    @map("patient_id") @db.Uuid
  toothNumber Int       @map("tooth_number")
  condition   String
  notes       String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@unique([tenantId, patientId, toothNumber])
  @@map("tooth_conditions")
}

model OralCondition {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  patientId String    @map("patient_id") @db.Uuid
  name      String
  active    Boolean?  @default(true)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@unique([tenantId, patientId, name])
  @@map("oral_conditions")
}

model OralTissueFinding {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  patientId String    @map("patient_id") @db.Uuid
  name      String
  status    String
  notes     String?
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@unique([tenantId, patientId, name])
  @@map("oral_tissue_findings")
}

model PeriodontalMeasurement {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  patientId       String?   @map("patient_id") @db.Uuid
  toothNumber     Int       @map("tooth_number")
  parameterName   String    @map("parameter_name")
  buccalValues    Int[]     @map("buccal_values")
  lingualValues   Int[]     @map("lingual_values")
  singleValue     Int?      @map("single_value")
  measurementDate DateTime? @default(now()) @map("measurement_date") @db.Date
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient? @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("periodontal_measurements")
}

model PatientDocument {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  patientId  String    @map("patient_id") @db.Uuid
  name       String
  type       String
  fileUrl    String    @map("file_url")
  uploadDate DateTime? @default(now()) @map("upload_date") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, uploadDate])
  @@map("patient_documents")
}

model PatientSurgery {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  patientId   String    @map("patient_id") @db.Uuid
  surgeryName String    @map("surgery_name")
  surgeryDate DateTime? @map("surgery_date") @db.Date
  notes       String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("patient_surgeries")
}

model PatientFamilyHistory {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  patientId     String    @map("patient_id") @db.Uuid
  conditionName String    @map("condition_name")
  relation      String?
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("patient_family_history")
}
