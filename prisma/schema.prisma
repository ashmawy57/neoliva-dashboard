generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String
  slug                    String                   @unique
  createdAt               DateTime?                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime?                @default(now()) @map("updated_at") @db.Timestamptz(6)
  status                  TenantStatus             @default(PENDING)
  appointments            Appointment[]
  expenses                Expense[]
  inventory               Inventory[]
  invoiceItems            InvoiceItem[]
  invoices                Invoice[]
  labOrders               LabOrder[]
  medicalConditions       MedicalCondition[]
  oralConditions          OralCondition[]
  oralTissueFindings      OralTissueFinding[]
  patientAllergies        PatientAllergy[]
  patientDocuments        PatientDocument[]
  patientFamilyHistory    PatientFamilyHistory[]
  patientMedications      PatientMedication[]
  patientSurgeries        PatientSurgery[]
  patients                Patient[]
  payments                Payment[]
  periodontalMeasurements PeriodontalMeasurement[]
  prescriptionItems       PrescriptionItem[]
  prescriptions           Prescription[]
  services                Service[]
  staff                   Staff[]
  toothConditions         ToothCondition[]
  treatmentPlanItems      TreatmentPlanItem[]
  treatmentPlans          TreatmentPlan[]
  visitRecords            VisitRecord[]
  inventoryItems          InventoryItem[]
  stockEntries            StockEntry[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  ledgerAccounts          LedgerAccount[]
  journalEntries          JournalEntry[]
  businessEvents          BusinessEvent[]
  
  staffInvitations        StaffInvitation[]
  memberships             TenantMembership[]
  rooms                   Room[]

  @@index([createdAt])
  @@map("tenants")

  auditLogs AuditLog[]
  clinicSettings          ClinicSettings?
}

model User {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supabaseId String    @unique @map("supabase_id")
  email      String    @unique
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  
  // A user can belong to multiple tenants
  memberships TenantMembership[]
  // Invitations sent by this user
  sentInvitations StaffInvitation[] @relation("InvitedByUser")
  
  notifications Notification[]
  notificationPreferences NotificationPreference[]
  businessEvents          BusinessEvent[]
  auditLogs               AuditLog[]
  roomAssignments         RoomStaff[]

  @@index([supabaseId])
  @@map("users")
}

model TenantMembership {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  tenantId     String           @map("tenant_id") @db.Uuid
  role         StaffRole        @default(RECEPTIONIST)
  status       MembershipStatus @default(ACTIVE)
  permissions  String[]         @default([])
  isActive     Boolean          @default(true) @map("is_active")
  joinedAt     DateTime         @default(now()) @map("joined_at") @db.Timestamptz(6)
  
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffProfile Staff?

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@map("tenant_memberships")
}

model Staff {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId       String?        @unique @map("display_id")
  name            String
  role            StaffRole
  title           String?
  email           String         @unique
  phone           String?
  status          String?        @default("Online")
  createdAt       DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?      @default(now()) @map("updated_at") @db.Timestamptz(6)
  avatarUrl       String?        @map("avatar_url")
  tenantId        String         @map("tenant_id") @db.Uuid
  
  // Relation to membership for active users
  membershipId    String?        @unique @map("membership_id") @db.Uuid
  membership      TenantMembership? @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  appointments    Appointment[]
  prescriptions   Prescription[]
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("staff")
}

model StaffInvitation {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String           @map("tenant_id") @db.Uuid
  email        String
  fullName     String           @map("full_name")
  role         StaffRole
  status       InvitationStatus @default(PENDING)
  jobTitle     String?          @map("job_title")
  permissions  String[]         @default([])
  tokenHash    String           @unique @map("token_hash")
  invitedById  String           @map("invited_by_id") @db.Uuid
  expiresAt    DateTime         @map("expires_at") @db.Timestamptz(6)
  acceptedAt   DateTime?        @map("accepted_at") @db.Timestamptz(6)
  revokedAt    DateTime?        @map("revoked_at") @db.Timestamptz(6)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy    User             @relation("InvitedByUser", fields: [invitedById], references: [id])

  @@index([tenantId, email])
  @@index([tokenHash])
  @@map("staff_invitations")
}

model Patient {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId               String?                  @unique @map("display_id")
  name                    String
  email                   String?
  phone                   String?
  dob                     DateTime?                @db.Date
  gender                  String?
  bloodGroup              String?                  @map("blood_group")
  avatarInitials          String?                  @map("avatar_initials")
  colorGradient           String?                  @map("color_gradient")
  createdAt               DateTime?                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime?                @default(now()) @map("updated_at") @db.Timestamptz(6)
  phone2                  String?
  address                 String?
  postCode                String?                  @map("post_code")
  city                    String?
  maritalStatus           String?                  @map("marital_status")
  occupation              String?
  insurance               String?
  ssn                     String?
  idNumber                String?                  @map("id_number")
  medicalAlert            String?                  @map("medical_alert")
  referredBy              String?                  @map("referred_by")
  notes                   String?
  isDeceased              Boolean?                 @default(false) @map("is_deceased")
  isSigned                Boolean?                 @default(false) @map("is_signed")
  status                  String?                  @default("Active")
  smokingStatus           String?                  @default("Never") @map("smoking_status")
  alcoholUse              String?                  @default("None") @map("alcohol_use")
  medicalNotes            String?                  @map("medical_notes")
  tenantId                String                   @map("tenant_id") @db.Uuid
  appointments            Appointment[]
  invoices                Invoice[]
  labOrders               LabOrder[]
  medicalConditions       MedicalCondition[]
  oralConditions          OralCondition[]
  oralTissueFindings      OralTissueFinding[]
  patientAllergies        PatientAllergy[]
  patientDocuments        PatientDocument[]
  patientFamilyHistory    PatientFamilyHistory[]
  patientMedications      PatientMedication[]
  patientSurgeries        PatientSurgery[]
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments                Payment[]
  periodontalMeasurements PeriodontalMeasurement[]
  prescriptions           Prescription[]
  toothConditions         ToothCondition[]
  treatmentPlans          TreatmentPlan[]
  visitRecords            VisitRecord[]

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("patients")
}

model Appointment {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String             @map("patient_id") @db.Uuid
  doctorId  String             @map("doctor_id") @db.Uuid
  serviceId String?            @map("service_id") @db.Uuid
  date      DateTime           @db.Date
  time      DateTime           @db.Time(6)
  duration  Int
  notes     String?
  createdAt DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?          @default(now()) @map("updated_at") @db.Timestamptz(6)
  displayId String?            @unique @map("display_id")
  treatment String?
  color     String?
  tenantId  String             @map("tenant_id") @db.Uuid
  status    AppointmentStatus? @default(SCHEDULED)
  
  roomId    String?            @map("room_id") @db.Uuid
  chairId   String?            @map("chair_id") @db.Uuid

  doctor    Staff              @relation(fields: [doctorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient   Patient            @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  service   Service?           @relation(fields: [serviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  room      Room?              @relation(fields: [roomId], references: [id], onDelete: SetNull)
  chair     RoomChair?         @relation(fields: [chairId], references: [id], onDelete: SetNull)
  
  invoice   Invoice?
  labOrders LabOrder[]

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@index([roomId])
  @@map("appointments")
}

model Room {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  name        String
  slug        String      
  type        RoomType    @default(GENERAL)
  description String?
  status      RoomStatus  @default(AVAILABLE)
  color       String?
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  roomStaff    RoomStaff[]
  roomChairs   RoomChair[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("rooms")
}

model RoomStaff {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId     String   @map("room_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  role       String?
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@map("room_staff")
}

model RoomChair {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId   String  @map("room_id") @db.Uuid
  name     String
  code     String?
  isActive Boolean @default(true) @map("is_active")

  room         Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([roomId])
  @@map("room_chairs")
}

enum RoomType {
  GENERAL
  SURGERY
  XRAY
  CONSULTATION
  CLEANING
  WHITENING
}

enum RoomStatus {
  AVAILABLE
  BUSY
  CLEANING
  MAINTENANCE
  OFFLINE
}

model Service {
  id                 String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  price              Decimal                 @db.Decimal
  description        String?
  popular            Boolean?                @default(false)
  createdAt          DateTime?               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime?               @default(now()) @map("updated_at") @db.Timestamptz(6)
  duration           Int
  tenantId           String                  @map("tenant_id") @db.Uuid
  isActive           Boolean                 @default(true) @map("is_active")
  category           ServiceCategory
  appointments       Appointment[]
  inventoryUsages    ServiceInventoryUsage[]
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  treatmentPlanItems TreatmentPlanItem[]

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("services")
}

model Invoice {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId     String?       @unique @map("display_id")
  patientId     String        @map("patient_id") @db.Uuid
  createdAt     DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?     @default(now()) @map("updated_at") @db.Timestamptz(6)
  treatment     String?
  tenantId      String        @map("tenant_id") @db.Uuid
  dueDate       DateTime?     @map("due_date") @db.Date
  status        InvoiceStatus @default(PENDING)
  appointmentId String?       @unique @map("appointment_id") @db.Uuid
  paidAmount    Decimal       @default(0) @map("paid_amount") @db.Decimal
  totalAmount   Decimal       @map("total_amount") @db.Decimal
  items         InvoiceItem[]
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id])
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments      Payment[]

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId   String  @map("invoice_id") @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  description String
  price       Decimal @db.Decimal
  quantity    Int     @default(1)
  serviceId   String? @map("service_id") @db.Uuid
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, invoiceId])
  @@map("invoice_items")
}

model Payment {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId String?       @map("invoice_id") @db.Uuid
  patientId String?       @map("patient_id") @db.Uuid
  amount    Decimal       @db.Decimal
  notes     String?
  tenantId  String        @map("tenant_id") @db.Uuid
  paidAt    DateTime      @default(now()) @map("paid_at") @db.Timestamptz(6)
  method    PaymentMethod
  invoice   Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  patient   Patient?      @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, invoiceId])
  @@index([tenantId, patientId])
  @@map("payments")
}

model Expense {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId   String?        @unique @map("display_id")
  title       String
  category    String
  description String?
  amount      Decimal        @db.Decimal
  date        DateTime       @db.Date
  createdAt   DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime?      @default(now()) @map("updated_at") @db.Timestamptz(6)
  method      String?
  tenantId    String         @map("tenant_id") @db.Uuid
  status      ExpenseStatus? @default(PAID)
  notes       String?
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("expenses")
}

model Inventory {
  id        String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId String?                 @unique @map("display_id")
  name      String
  category  String
  quantity  Int                     @default(0)
  minLevel  Int                     @default(10) @map("min_level")
  unit      String?
  createdAt DateTime?               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?               @default(now()) @map("updated_at") @db.Timestamptz(6)
  minStock  Int?                    @default(0) @map("min_stock")
  location  String?
  supplier  String?
  tenantId  String                  @map("tenant_id") @db.Uuid
  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usages    ServiceInventoryUsage[]

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("inventory")
}

model ServiceInventoryUsage {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId   String    @map("service_id") @db.Uuid
  inventoryId String    @map("inventory_id") @db.Uuid
  quantity    Int       @default(1)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  tenantId    String    @map("tenant_id") @db.Uuid
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, inventoryId])
  @@index([tenantId, serviceId])
  @@map("service_inventory_usage")
}

model LabOrder {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId     String?        @unique @map("display_id")
  tenantId      String         @map("tenant_id") @db.Uuid
  patientId     String         @map("patient_id") @db.Uuid
  appointmentId String?        @map("appointment_id") @db.Uuid
  labName       String         @map("lab_name")
  itemType      String         @map("item_type")
  toothNumber   String?        @map("tooth_number")
  status        LabOrderStatus @default(PENDING)
  sentAt        DateTime?      @map("sent_at") @db.Timestamptz(6)
  dueDate       DateTime?      @map("due_date") @db.Date
  receivedAt    DateTime?      @map("received_at") @db.Timestamptz(6)
  cost          Decimal?       @db.Decimal
  notes         String?
  createdAt     DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?      @default(now()) @map("updated_at") @db.Timestamptz(6)
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("lab_orders")
}

model TreatmentPlan {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String              @map("patient_id") @db.Uuid
  title     String
  status    String?             @default("Active")
  notes     String?
  createdAt DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?           @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenantId  String              @map("tenant_id") @db.Uuid
  items     TreatmentPlanItem[]
  patient   Patient             @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("treatment_plans")
}

model TreatmentPlanItem {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId        String        @map("plan_id") @db.Uuid
  serviceId     String?       @map("service_id") @db.Uuid
  serviceName   String        @map("service_name")
  toothList     String?       @map("tooth_list")
  price         Decimal       @db.Decimal
  status        String?       @default("Planned")
  createdAt     DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?     @default(now()) @map("updated_at") @db.Timestamptz(6)
  step          Int?
  scheduledDate DateTime?     @map("scheduled_date") @db.Date
  notes         String?
  tenantId      String        @map("tenant_id") @db.Uuid
  plan          TreatmentPlan @relation(fields: [planId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  service       Service?      @relation(fields: [serviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("treatment_plan_items")
}

model Prescription {
  id         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId  String             @map("patient_id") @db.Uuid
  doctorId   String?            @map("doctor_id") @db.Uuid
  date       DateTime?          @default(now()) @map("date") @db.Timestamptz(6)
  notes      String?
  createdAt  DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime?          @default(now()) @map("updated_at") @db.Timestamptz(6)
  doctorName String?            @map("doctor_name")
  tenantId   String             @map("tenant_id") @db.Uuid
  items      PrescriptionItem[]
  doctor     Staff?             @relation(fields: [doctorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient    Patient            @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prescriptionId String       @map("prescription_id") @db.Uuid
  medicationName String       @map("medication_name")
  dosage         String?
  frequency      String?
  duration       String?
  createdAt      DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)
  tenantId       String       @map("tenant_id") @db.Uuid
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("prescription_items")
}

model PatientAllergy {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String    @map("patient_id") @db.Uuid
  severity  String?   @default("outline")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenantId  String    @map("tenant_id") @db.Uuid
  allergen  String?
  notes     String?
  reaction  String?
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, id])
  @@index([tenantId, patientId])
  @@index([tenantId, createdAt])
  @@map("patient_allergies")
}

model MedicalCondition {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId     String    @map("patient_id") @db.Uuid
  diagnosedDate DateTime? @map("diagnosed_date") @db.Date
  status        String?
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
